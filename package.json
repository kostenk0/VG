{
  "name": "vg",
  "version": "0.0.0",
  "private": true,
  "description": "VisaForge monorepo — AI-assisted US immigration self-filing platform.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.18.0 <21"
  },
  "scripts": {
    "landing:dev": "pnpm --filter @vg/landing dev",
    "landing:build": "pnpm --filter @vg/landing build",
    "landing:preview": "pnpm --filter @vg/landing preview",
    "landing:test": "pnpm --filter @vg/landing test",
    "landing:e2e": "pnpm --filter @vg/landing e2e",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {}
}
