{
  "name": "vg",
  "version": "0.0.0",
  "private": true,
  "description": "VisaForge monorepo — AI-assisted US immigration self-filing platform.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.18.0 <21"
  },
  "scripts": {
    "landing:dev": "pnpm --filter @vg/landing dev",
    "landing:build": "pnpm --filter @vg/landing build",
    "landing:preview": "pnpm --filter @vg/landing preview",
    "landing:test": "pnpm --filter @vg/landing test",
    "landing:e2e": "pnpm --filter @vg/landing e2e",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.59.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
